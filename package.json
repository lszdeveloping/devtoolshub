{
  "name": "devtoolshub",
  "version": "1.2.0",
  "description": "DevTools Hub IDE - Installer & Manager for Windows",
  "main": "dist/main/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lszdeveloping/devtoolshub.git"
  },
  "bugs": {
    "url": "https://github.com/lszdeveloping/devtoolshub/issues"
  },
  "homepage": "https://github.com/lszdeveloping/devtoolshub#readme",
  "bin": {
    "devtoolshub": "./dist/cli/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:vite && npm run build:main && npm run build:cli",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "start": "electron ."
  },
  "keywords": [
    "devtools",
    "installer",
    "electron",
    "cli"
  ],
  "author": "DevTools Hub Team",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "lucide-react": "^0.460.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "build": {
    "appId": "io.devtoolshub.app",
    "productName": "DevTools Hub",
    "files": [
      "dist/**/*",
      "installers/**/*",
      "resources/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "installers/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
